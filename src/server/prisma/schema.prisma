generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserType {
  student
  administrator
}

model User {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  email     String   @unique
  password  String
  isBlocked Boolean  @default(false) @map("is_blocked")
  type      UserType

  loans   Loan[]
  reviews Review[]

  @@map("users")
}

model Book {
  id             String @id @default(uuid())
  slug           String @unique
  isbn           String @unique
  name           String
  year           Int    @map("year")
  authorId       String @map("author_id")
  description    String
  categories     String
  totalQuantity  Int    @map("total_quantity")
  totalAvailable Int    @map("total_available")

  author    Author     @relation(fields: [authorId], references: [id])
  wishlists Wishlist[]
  loans     Loan[]

  @@map("books")
}

enum LoanStatus {
  in_progress
  returned
  canceled
  overdue
}

model Loan {
  id         String     @id @default(uuid())
  studentId  String     @map("student_id")
  editionId  String     @map("edition_id")
  loanDate   DateTime   @map("loan_date")
  dueDate    DateTime   @map("due_date")
  returnDate DateTime?  @map("return_date")
  status     LoanStatus

  student User    @relation(fields: [studentId], references: [id])
  edition Edition @relation(fields: [editionId], references: [id])

  @@map("loans")
}

model Author {
  id    String @id @default(uuid())
  name  String
  books Book[]

  @@map("authors")
}

model Edition {
  id        String @id @default(uuid())
  bookId    String @map("book_id")
  year      Int
  publisher String
  ISBN      String

  totalQuantity     Int @map("total_quantity")
  quantityAvailable Int @map("quantity_available")

  book  Book   @relation(fields: [bookId], references: [id])
  loans Loan[]

  @@map("editions")
}

model Review {
  id          String   @id @default(uuid())
  rating      Int
  studentId   String   @map("student_id")
  bookId      String   @map("book_id")
  description String?
  date        DateTime

  student User @relation(fields: [studentId], references: [id])
  book    Book @relation(fields: [bookId], references: [id])

  @@map("reviews")
}
